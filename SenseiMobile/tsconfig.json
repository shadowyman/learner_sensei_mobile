{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "typeRoots": ["./node_modules/@types", "./node_modules/react-native/types"],
    "skipLibCheck": true,
    "types": ["react-native", "jest"],
    "paths": {
      "react-native": ["./node_modules/@types/react-native"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["**/node_modules", "**/Pods", "src/mobile/webviewBridge.ts"]
}
