{
  "name": "sensei-ai-education-system",
  "version": "1.0.0",
  "description": "AI-powered personalized education system",
  "main": "index.tsx",
  "scripts": {
    "test": "jest --silent --bail --noStackTrace",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "snyk-test": "snyk test",
    "snyk-monitor": "snyk monitor",
    "sonar": "./sonar",
    "review": "ts-node scripts/generateReview.ts",
    "review:create": "ts-node scripts/generateReview.ts",
    "review:context": "ts-node scripts/reviewContext.ts",
    "review:edit": "ts-node scripts/reviewEdit.ts",
    "review:result": "ts-node scripts/reviewEdit.ts result",
    "review:dispatch": "python3 scripts/sync_review.py",
    "review:hook:prepush": "ts-node scripts/prePushCleanup.ts",
    "hooks:install": "node scripts/installGitHooks.js",
    "postinstall": "npm run hooks:install",
    "manifest:sync": "ts-node scripts/manifestSync.ts",
    "analysis:run": "npm run manifest:sync && ts-node scripts/analyze.ts",
    "analysis:dom": "npm run analysis:run -- --preset domsuite",
    "analysis:ui": "npm run analysis:run -- --preset ui",
    "analysis:notepad": "npm run analysis:run -- --preset notepad",
    "functional:analyzer": "ts-node tests/analyzer.integration.ts",
    "functional:review-cli": "ts-node tests/reviewEdit.functional.test.ts",
    "functional:adaptive-engine": "ts-node tests/adaptiveEngine.functional.test.ts",
    "backup:create": "npm run manifest:sync && ts-node scripts/createBackup.ts",
    "test:lint": "eslint --config config/eslint.config.cjs",
    "review:mediate": "node --require ts-node/register scripts/review_mediator.ts",
    "webview:bundle": "npm run core:build && mkdir -p SenseiMobile/app_web/webview_dist && esbuild src/index.tsx --bundle --format=esm --platform=browser --target=es2020 --sourcemap --define:process.env.NODE_ENV='\"production\"' --outfile=SenseiMobile/app_web/webview_dist/index.js --loader:.ts=ts --loader:.tsx=tsx --loader:.txt=text --external:@google/genai --external:marked --external:mermaid --external:jszip --external:@google/generative-ai --external:@codemirror/state --external:@codemirror/view --external:@codemirror/language --external:@codemirror/commands --external:@codemirror/autocomplete --external:@codemirror/lang-cpp --external:@codemirror/highlight --external:@codemirror/gutter --external:@lezer/highlight --external:w3c-keyname --external:react-native --external:@react-native/assets-registry --external:react-native-safe-area-context && cp src/index.css SenseiMobile/app_web/webview_dist/index.css && cp src/index.html SenseiMobile/app_web/webview_dist/index.html && cp src/Modules.txt SenseiMobile/app_web/webview_dist/Modules.txt",
    "core:build": "cd core && npm run build"
  },
  "keywords": [
    "education",
    "ai",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@swc/jest": "^0.2.36",
    "@types/blessed": "^0.1.25",
    "@types/jest": "^29.5.12",
    "@types/node": "^24.5.2",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@typescript-eslint/parser": "^8.45.0",
    "esbuild": "^0.27.0",
    "eslint": "^9.36.0",
    "eslint-plugin-jest": "^29.0.1",
    "ignore": "^5.3.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-html-reporters": "^3.1.7",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@sensei/core": "file:./core",
    "codex": "^0.2.3",
    "json5": "^2.2.3",
    "katex": "^0.16.23",
    "marked-katex-extension": "^5.1.5",
    "neo-blessed": "^0.2.0",
    "parse5": "^8.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "string-width": "^7.1.0",
    "strip-ansi": "^7.1.0",
    "wrap-ansi": "^9.0.0"
  }
}
