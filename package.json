{
  "name": "sensei-ai-education-system",
  "version": "1.0.0",
  "description": "AI-powered personalized education system",
  "main": "index.tsx",
  "scripts": {
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "snyk-test": "snyk test",
    "snyk-monitor": "snyk monitor",
    "sonar": "./sonar",
    "review": "ts-node scripts/generateReview.ts",
    "review:create": "ts-node scripts/generateReview.ts",
    "review:edit": "ts-node scripts/reviewEdit.ts",
    "review:result": "ts-node scripts/reviewEdit.ts result",
    "review:dispatch": "python3 scripts/sync_review.py",
    "analysis:run": "ts-node scripts/analyze.ts",
    "analysis:dom": "npm run analysis:run -- --preset domsuite",
    "analysis:ui": "npm run analysis:run -- --preset ui",
    "analysis:notepad": "npm run analysis:run -- --preset notepad",
    "functional:analyzer": "ts-node tests/analyzer.integration.ts",
    "functional:review-cli": "ts-node tests/reviewEdit.functional.test.ts",
    "functional:adaptive-engine": "ts-node tests/adaptiveEngine.functional.test.ts",
    "backup:create": "ts-node scripts/createBackup.ts",
    "test:lint": "eslint --config config/eslint.config.cjs"
  },
  "keywords": [
    "education",
    "ai",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@swc/jest": "^0.2.36",
    "@types/jest": "^29.5.12",
    "@types/node": "^24.5.2",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@typescript-eslint/parser": "^8.45.0",
    "eslint": "^9.36.0",
    "eslint-plugin-jest": "^29.0.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-html-reporters": "^3.1.7",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "parse5": "^8.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  }
}
